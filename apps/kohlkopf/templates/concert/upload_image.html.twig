{% extends 'base.html.twig' %}

{% block title %}Konzertbild hochladen{% endblock %}

{% block page_title %}Bild für {{ concert.title }}{% endblock %}

{% block content %}
    <div class="container py-4">
        <div class="card shadow-sm">
            <div class="card-body">
                {% if concert.artistImage %}
                    <div class="mb-3">
                        <div class="small text-muted mb-2">Aktuelles Bild</div>
                        <img src="{{ concert.artistImage }}"
                             alt="{{ concert.title }}"
                             class="rounded border"
                             style="width: 160px; height: 160px; object-fit: cover;">
                    </div>
                {% endif %}

                <form method="post" enctype="multipart/form-data" class="mb-3">
                    <input type="hidden" name="_token" value="{{ csrf_token('concert_image_upload_' ~ concert.id) }}">

                    <div class="mb-3">
                        <label class="form-label" for="artist-image">Neues Bild (JPG, PNG, WEBP, GIF; max. 5 MB)</label>
                        <input id="artist-image"
                               type="file"
                               name="artist_image"
                               accept="image/jpeg,image/png,image/webp,image/gif"
                               class="form-control"
                               required>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-upload me-1"></i>Bild hochladen
                        </button>
                        <a href="{{ path('concert_show', {id: concert.id}) }}" class="btn btn-outline-secondary">Zurück</a>
                    </div>
                </form>

                {% if concert.artistImage %}
                    <form method="post" onsubmit="return confirm('Bild wirklich entfernen?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('concert_image_upload_' ~ concert.id) }}">
                        <input type="hidden" name="remove_image" value="1">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-trash me-1"></i>Bild entfernen
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
